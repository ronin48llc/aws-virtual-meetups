{
  "name": "virtual-meetup-platform",
  "version": "1.0.0",
  "description": "Virtual Meetup Platform - Serverless AWS application for hosting live meetup sessions",
  "main": "bin/app.js",
  "scripts": {
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:property": "jest --testPathPattern=test/property",
    "test:integration": "jest --testPathPattern=test/integration"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.150.0",
    "aws-jwt-verify": "^5.1.1",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1047.0",
    "@aws-sdk/client-dynamodb": "^3.1047.0",
    "@aws-sdk/client-ivs-realtime": "^3.1047.0",
    "@aws-sdk/client-ivschat": "^3.1047.0",
    "@aws-sdk/client-lambda": "^3.1047.0",
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/client-scheduler": "^3.1047.0",
    "@aws-sdk/client-secrets-manager": "^3.1047.0",
    "@aws-sdk/client-ses": "^3.1047.0",
    "@aws-sdk/lib-dynamodb": "^3.1047.0",
    "aws-cdk": "^2.150.0",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "jsdom": "^29.1.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  }
}
